# Copy this file to .env.local and fill in your local values.
# Do not commit .env.local.
# For local development against Azure PostgreSQL Flexible Server, set
# DATABASE_URL and DATABASE_URL_UNPOOLED to the same Azure connection string
# with sslmode=verify-full.

AUTH_SEED_EMAIL=""
AUTH_SEED_PASSWORD=""
AUTH_SEED_PASSWORD_HASH=""
DATABASE_URL=""
DATABASE_URL_UNPOOLED=""
NEXTAUTH_SECRET="replace-with-a-long-random-secret"
NEXTAUTH_URL="http://localhost:9002"
NEXT_PUBLIC_APP_URL="http://localhost:9002"
OPENAI_API_KEY=""
OPENAIP_API_KEY=""
NEXT_PUBLIC_MAPLIBRE_LIGHT_STYLE_URL=""
NEXT_PUBLIC_MAPLIBRE_SATELLITE_STYLE_URL=""
NEXT_PUBLIC_OPENAIP_VECTOR_TILE_URL=""
RESEND_API_KEY=""
MAIL_FROM=""
AZURE_STORAGE_CONNECTION_STRING=""
AZURE_STORAGE_CONTAINER_NAME="uploads"
