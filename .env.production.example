# Production environment variables are managed in Azure App Service.
# Copy these keys into App Service > Environment variables.

AUTH_SEED_EMAIL=""
AUTH_SEED_PASSWORD_HASH=""
DATABASE_URL=""
DATABASE_URL_UNPOOLED=""
MAIL_FROM=""
NEXTAUTH_SECRET="replace-with-a-long-random-secret"
