generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id                    String                 @id @db.VarChar(128)
  name                  String
  createdAt             DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime               @default(now()) @map("updated_at") @db.Timestamptz(6)
  users                 User[]
  roles                 Role[]
  departments           Department[]
  personnel             Personnel[]
  tenantConfigs         TenantConfig[]
  managementOfChanges   ManagementOfChange[]
  qualityAudits         QualityAudit[]
  safetyReports         SafetyReport[]
  correctiveActionPlans CorrectiveActionPlan[]
  risks                 Risk[]
  aircrafts             AircraftRecord[]
  vehicles              VehicleRecord[]
  vehicleUsageRecords   VehicleUsageRecord[]
  bookings              BookingRecord[]
  attendanceRecords     AttendanceRecord[]
  trainingRoutes        TrainingRouteRecord[]
  meetings              MeetingRecord[]
  companyDocuments      CompanyDocument[]
  externalOrganizations ExternalOrganization[]
  betaNdaAcceptances    BetaNdaAcceptance[]
  erpStates             ErpState[]
  workpacks             WorkpackRecord[]
  maintenanceTaskCards  MaintenanceTaskCardRecord[]
  tools                 ToolRecord[]
  activeFlightSessions  ActiveFlightSessionRecord[]
  activeFlightSessionBlocks ActiveFlightSessionBlock[]
  activeFlightTrackPoints ActiveFlightTrackPointRecord[]
  alerts                AlertRecord[]
  passwordSetupInvites  PasswordSetupInvite[]

  @@map("tenants")
}

model User {
  id           String   @id @db.VarChar(128)
  tenantId     String   @map("tenant_id") @db.VarChar(128)
  email        String   @unique
  passwordHash String?  @map("password_hash")
  suspendedAt  DateTime? @map("suspended_at") @db.Timestamptz(6)
  firstName    String   @default("") @map("first_name")
  lastName     String   @default("") @map("last_name")
  role         String   @default("developer")
  profilePath  String?  @map("profile_path")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  passwordSetupInvites PasswordSetupInvite[]

  @@map("users")
}

model PasswordSetupInvite {
  id         String   @id @db.VarChar(128)
  tenantId   String   @map("tenant_id") @db.VarChar(128)
  userId     String?  @map("user_id") @db.VarChar(128)
  email      String
  name       String?
  tokenHash  String   @unique @map("token_hash")
  expiresAt  DateTime @map("expires_at") @db.Timestamptz(6)
  usedAt     DateTime? @map("used_at") @db.Timestamptz(6)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("password_setup_invites")
}

model BetaNdaAcceptance {
  id               String   @id @db.VarChar(128)
  tenantId         String   @default("safeviate") @map("tenant_id") @db.VarChar(128)
  email            String
  name             String
  ndaVersion       String   @map("nda_version")
  agreementText    String   @map("agreement_text") @db.Text
  signatureDataUrl  String  @map("signature_data_url") @db.Text
  acceptedAt       DateTime @map("accepted_at") @db.Timestamptz(6)
  ipAddress        String?  @map("ip_address")
  userAgent        String?  @map("user_agent")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, email, ndaVersion])
  @@map("beta_nda_acceptances")
}

model Role {
  id                String   @id @db.VarChar(128)
  tenantId          String   @map("tenant_id") @db.VarChar(128)
  name              String
  permissions       Json     @default("[]")
  accessOverrides   Json?    @map("access_overrides")
  requiredDocuments Json?    @map("required_documents")
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("roles")
}

model Department {
  id        String   @id @db.VarChar(128)
  tenantId  String   @map("tenant_id") @db.VarChar(128)
  name      String
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("departments")
}

model Personnel {
  id                   String   @id @db.VarChar(128)
  tenantId             String   @map("tenant_id") @db.VarChar(128)
  userNumber           String?  @map("user_number")
  firstName            String   @map("first_name")
  lastName             String   @map("last_name")
  email                String
  contactNumber        String?  @map("contact_number")
  organizationId       String?  @map("organization_id")
  department           String?
  role                 String
  permissions          Json     @default("[]")
  accessOverrides      Json?    @map("access_overrides")
  documents            Json     @default("[]")
  userType             String   @default("Personnel") @map("user_type")
  canBeInstructor      Boolean  @default(false) @map("can_be_instructor")
  canBeStudent         Boolean  @default(false) @map("can_be_student")
  canBePIC             Boolean  @default(false) @map("can_be_pic")
  isErpIncerfaContact  Boolean  @default(false) @map("is_erp_incerfa_contact")
  isErpAlerfaContact   Boolean  @default(false) @map("is_erp_alerfa_contact")
  createdAt            DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)
  tenant               Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("personnel")
}

model TenantConfig {
  tenantId  String   @map("tenant_id") @db.VarChar(128)
  data      Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@id([tenantId])
  @@map("tenant_configs")
}

